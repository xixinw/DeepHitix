# Copy to .env and fill the required values.
# Do not commit deploy/.env.

# Required: DeepSeek API key used by the container.
DEEPSEEK_API_KEY=

# Required: API server bearer key. Generate with:
#   openssl rand -hex 32
# or any secure random 32+ char string.
API_SERVER_KEY=

# Image/container settings.
# The compose base builds a thin project image that extends upstream Hermes and
# installs Feishu optional dependencies (`lark-oapi`, `qrcode`).
DEEPSEEK_NATIVE_IMAGE=deepseek-native-agent:latest
HERMES_BASE_IMAGE=nousresearch/hermes-agent:latest
# Optional PyPI mirrors for regions where pypi.org is slow/unreachable.
PIP_INDEX_URL=
PIP_EXTRA_INDEX_URL=
DEEPSEEK_NATIVE_CONTAINER=deepseek-native-agent
DEEPSEEK_NATIVE_DATA_DIR=./data

# Local-only by default. For a remote server, keep this behind SSH tunnel or reverse proxy.
API_SERVER_BIND=127.0.0.1
API_SERVER_PORT=8642
API_SERVER_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Gateway user authorization. Keep false for production unless the deployment
# is otherwise restricted; use FEISHU_ALLOWED_USERS for a tighter Feishu setup.
GATEWAY_ALLOW_ALL_USERS=false

# DeepSeek-native defaults.
HERMES_INFERENCE_PROVIDER=deepseek
HERMES_MODEL=deepseek-v4-flash
DEEPSEEK_NATIVE_ROUTING_ENABLED=true
DEEPSEEK_NATIVE_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_NATIVE_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_NATIVE_TELEMETRY_ENABLED=true

# Chat platforms are off by default for the Docker smoke base.
# Feishu deployment guide can opt in by setting FEISHU_ENABLED=true and credentials.
FEISHU_ENABLED=false
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ALLOWED_USERS=
FEISHU_HOME_CHANNEL=
FEISHU_HOME_CHANNEL_NAME=Home
FEISHU_HOME_CHANNEL_THREAD_ID=
