ARG HERMES_BASE_IMAGE=nousresearch/hermes-agent:latest
FROM ${HERMES_BASE_IMAGE}

USER root
WORKDIR /opt/hermes

ARG PIP_INDEX_URL=
ARG PIP_EXTRA_INDEX_URL=

ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

# Overlay the clean branch 5 source onto the upstream Hermes runtime image.
# This avoids a full production-image rebuild on small smoke hosts while still
# making the published image contain the DeepSeek-native code under test.
COPY --chown=hermes:hermes . /opt/hermes

RUN set -eux; \
    pip_args=""; \
    if [ -n "${PIP_INDEX_URL}" ]; then pip_args="$pip_args --index-url ${PIP_INDEX_URL}"; fi; \
    if [ -n "${PIP_EXTRA_INDEX_URL}" ]; then pip_args="$pip_args --extra-index-url ${PIP_EXTRA_INDEX_URL}"; fi; \
    uv pip install --python /opt/hermes/.venv/bin/python3 --no-deps -e /opt/hermes; \
    uv pip install --python /opt/hermes/.venv/bin/python3 $pip_args \
      "lark-oapi==1.5.3" \
      "qrcode==7.4.2"; \
    /opt/hermes/.venv/bin/python3 - <<'PY'
import importlib.util
required = ("lark_oapi", "qrcode", "agent.routing_policy", "agent.cost_telemetry")
missing = [name for name in required if importlib.util.find_spec(name) is None]
if missing:
    raise SystemExit(f"missing release modules: {missing}")
print("PUBLIC_ALPHA_IMAGE_IMPORT_PROBE_PASS")
PY

USER hermes
